<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UBot.Avalonia.Dialogs.ProfileSelectionWindow"
        Title="SELECT PROFILE..."
        Width="450" Height="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

    <Border BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
        <StackPanel Spacing="15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="SELECT PROFILE..." 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource AccentBrush}"/>
                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        Classes="btn secondary"
                        Content="x"
                        Click="Close_Click"/>
            </Grid>
            <Separator Margin="0,-4,0,2"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Select a profile" Classes="label"/>
                <ComboBox x:Name="ProfileList" HorizontalAlignment="Stretch" Classes="field"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="New profile name" Classes="label"/>
                <TextBox x:Name="NewProfileBox" Classes="field"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,15,0,0">
                <CheckBox x:Name="SaveSelectionCheck" Grid.Column="0" Content="Save selection" IsChecked="True" Classes="check" VerticalAlignment="Center"/>
                <Button x:Name="AddBtn" Grid.Column="1" Classes="btn secondary" Content="+" Width="32" Margin="5,0,0,0" Click="AddProfile_Click" ToolTip.Tip="Add Profile"/>
                <Button x:Name="DeleteBtn" Grid.Column="2" Classes="btn secondary danger" Content="-" Width="32" Margin="5,0,0,0" Click="DeleteProfile_Click" ToolTip.Tip="Delete Profile"/>
                <Button Grid.Column="3" Classes="btn primary" Content="CONTINUE" Width="100" Margin="15,0,0,0" Click="Continue_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
