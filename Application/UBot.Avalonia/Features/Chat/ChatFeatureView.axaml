<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.Features.Chat.ChatFeatureView">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Tab strip -->
    <controls:TabStrip x:Name="ChatTabs" Grid.Row="0" />

    <!-- Send bar -->
    <Border Grid.Row="1" Classes="section-panel" Padding="10,8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Column="0" x:Name="ChannelLabel" Classes="form-label" VerticalAlignment="Center" />
        <TextBox   Grid.Column="1" x:Name="MessageBox" Classes="legacy-input" Watermark="Message..." />
        <TextBox   Grid.Column="2" x:Name="TargetBox"  Classes="legacy-input" Width="120" Watermark="Target..." IsVisible="False" />
        <Button    Grid.Column="3" x:Name="SendBtn" Classes="action-btn primary" Content="Send" Click="Send_Click" />
      </Grid>
    </Border>

    <!-- Chat log -->
    <Border Grid.Row="2" Classes="section-panel" Padding="0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="ChatLog">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock
                Text="{Binding .}"
                FontFamily="Consolas,Monospace"
                FontSize="11.5"
                Margin="8,1"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextPrimaryBrush}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

  </Grid>

</UserControl>

