<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="UBot.Avalonia.Features.Training.TrainingFeatureView">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="*,5,*" RowDefinitions="Auto,5,Auto,5,Auto" Margin="0,0,0,8">
      
<!-- ═══ Area (compact) ═══ -->
      <Border Grid.Row="0" Grid.Column="0" Classes="section-card">
        <Grid RowDefinitions="Auto,Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock x:Name="AreaTitle" Classes="section-header-text" />
          </Border>
          <TextBox x:Name="RegionBox" Grid.Row="1" IsVisible="False" Tag="areaRegion" />
          <StackPanel x:Name="AreaPanel" Grid.Row="2" Margin="4" Spacing="4">
            <StackPanel x:Name="AreaContent" Spacing="4">
              <Grid ColumnDefinitions="*,12,*">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="X" Classes="label" FontSize="9" Opacity="0.6" />
                  <TextBox x:Name="GlobalXBox" Classes="field" TextAlignment="Center" TextChanged="GlobalNumBox_Changed" Watermark="X" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Y" Classes="label" FontSize="9" Opacity="0.6" />
                  <TextBox x:Name="GlobalYBox" Classes="field" TextAlignment="Center" TextChanged="GlobalNumBox_Changed" Watermark="Y" />
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="*,12,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="R" Classes="label" FontSize="9" Opacity="0.6" />
                  <TextBox x:Name="RadiusBox" Classes="field" TextAlignment="Center" Tag="areaRadius" TextChanged="NumBox_Changed" Watermark="Radius" />
                </StackPanel>
                <Button Grid.Column="2" Classes="btn blue" x:Name="SetCurrentBtn" Click="SetCurrent_Click" VerticalAlignment="Bottom" Height="28" Padding="12,0" />
              </Grid>
              <Border Background="#0DFFFFFF" CornerRadius="4" Padding="10,6">
                <TextBlock x:Name="CurrentPositionLabel" FontSize="10" FontFamily="Consolas,Monospace" Foreground="{DynamicResource TextDimBrush}" HorizontalAlignment="Center" />
              </Border>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ═══ Back to Training ═══ -->
      <Border Grid.Row="0" Grid.Column="2" Classes="section-card">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock x:Name="BackTitle" Classes="section-header-text" />
          </Border>
          <StackPanel Grid.Row="1" Margin="4,4,4,4" Spacing="4">
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="WalkScriptBox" Grid.Column="0" Classes="field" Tag="walkScript" TextChanged="TextBox_Changed" Watermark="Walkscript Path" />
              <Button Grid.Column="1" Classes="browse-btn" Content="..." Click="BrowseWalkScript_Click" Margin="8,0,0,0" Width="36" />
            </Grid>
            
            <WrapPanel Margin="0,8,0,0">
              <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                <CheckBox x:Name="UseMountCheck" Tag="useMount"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
                <TextBlock Text="Mount" Classes="label" VerticalAlignment="Center" FontSize="10" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                <CheckBox x:Name="CastBuffsCheck" Tag="castBuffs"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
                <TextBlock Text="Buffs" Classes="label" VerticalAlignment="Center" FontSize="10" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                <CheckBox x:Name="UseSpeedCheck" Tag="useSpeedDrug"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
                <TextBlock Text="Speed" Classes="label" VerticalAlignment="Center" FontSize="10" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                <CheckBox x:Name="UseReverseCheck" Tag="useReverse"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
                <TextBlock Text="Reverse" Classes="label" VerticalAlignment="Center" FontSize="10" />
              </StackPanel>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ═══ Berserk ═══ -->
      <Border Grid.Row="2" Grid.Column="0" Classes="section-card">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock x:Name="BerserkTitle" Classes="section-header-text" />
          </Border>
          <StackPanel Grid.Row="1" Margin="4,4,4,4" Spacing="4">
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="BerserkFullCheck" Tag="berserkWhenFull"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="Full" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <CheckBox x:Name="BerserkCountCheck" Tag="berserkByMonsterAmount"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" />
              <TextBlock Text="Count" Classes="label" VerticalAlignment="Center" FontSize="10" />
              <TextBox x:Name="BerserkCountBox" Classes="field compact-num" Width="60" Tag="berserkMonsterAmount" TextChanged="NumBox_Changed" />
              <TextBlock x:Name="MonstersLabel" Classes="label" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="BerserkAvoidCheck" Tag="berserkByAvoidance"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="Avoid type" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="BerserkRarityCheck" Tag="berserkByMonsterRarity"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="Rarity" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ═══ Advanced ═══ -->
      <Border Grid.Row="2" Grid.Column="2" Classes="section-card">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock x:Name="AdvancedTitle" Classes="section-header-text" />
          </Border>
          <StackPanel Grid.Row="1" Margin="4,4,4,4" Spacing="4">
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="IgnorePillarCheck" Tag="ignoreDimensionPillar"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="Pillar" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="WeakerFirstCheck" Tag="attackWeakerFirst"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="Weaker" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <CheckBox x:Name="NoFollowCheck" Tag="dontFollowMobs"  Checked="Toggle_Changed" Unchecked="Toggle_Changed" Margin="0,0,8,0" />
              <TextBlock Text="No follow" Classes="label" VerticalAlignment="Center" FontSize="10" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ═══ Avoidance ═══ -->
      <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Classes="section-card">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock x:Name="AvoidTitle" Classes="section-header-text" />
          </Border>
          <StackPanel Grid.Row="1" Margin="8,8,8,8">
            <DataGrid x:Name="AvoidanceGrid"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="False"
                      IsReadOnly="False"
                      CanUserResizeColumns="True"
                      MinHeight="200" MaxHeight="220"
                      GridLinesVisibility="Horizontal"
                      RowBackground="Transparent">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="*" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Avoid" Width="80">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding Avoid}"  VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Prefer" Width="80">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding Prefer}"  VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Berserk" Width="80">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding Berserk}"  VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Grid>
      </Border>

    </Grid>
  </ScrollViewer>

</UserControl>

