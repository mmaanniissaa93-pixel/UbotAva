<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:protection="clr-namespace:UBot.Avalonia.Features.Protection"
  x:Class="UBot.Avalonia.Features.Protection.ProtectionFeatureView">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,12">
      
      <!-- Column 0 -->
      <StackPanel Grid.Column="0" Spacing="10">
        <!-- Recovery Card -->
        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Health / Mana Recovery" Classes="section-header-text" />
            </Border>
            <StackPanel Grid.Row="1" Margin="12,8" Spacing="4">
              <ItemsControl x:Name="RecoveryList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="protection:ThresholdRow">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,1">
                      <CheckBox Grid.Column="0" Content="{Binding Label}" IsChecked="{Binding Enabled}" Classes="legacy-check" VerticalAlignment="Center" FontSize="11.5" />
                      <TextBlock Grid.Column="1" Text="&lt;" VerticalAlignment="Center" Margin="6,0" Opacity="0.5" FontSize="11" />
                      <TextBox  Grid.Column="2" Text="{Binding Value}" Classes="field" Width="46" Height="26" Padding="4,0" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="11.5" />
                      <TextBlock Grid.Column="3" Text="%" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.5" FontSize="10.5" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Bad Status Card -->
        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Bad Status" Classes="section-header-text" />
            </Border>
            <StackPanel Grid.Row="1" Margin="12,8" Spacing="4">
              <CheckBox x:Name="UseUniversalPillsCheck" Classes="legacy-check" Tag="useUniversalPills" IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <CheckBox x:Name="UseBadStatusSkillCheck" Classes="legacy-check" Tag="useBadStatusSkill" IsCheckedChanged="Check_Changed" FontSize="11.5" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Pet Recovery Card -->
        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Recovery - Pet" Classes="section-header-text" />
            </Border>
            <StackPanel Grid.Row="1" Margin="12,8" Spacing="4">
              <CheckBox x:Name="PetHpCheck"      Classes="legacy-check" Tag="petHpPotionEnabled"           IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <CheckBox x:Name="PetHungerCheck"  Classes="legacy-check" Tag="petHgpPotionEnabled"          IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <CheckBox x:Name="PetAbnormCheck"  Classes="legacy-check" Tag="petAbnormalRecoveryEnabled"   IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <CheckBox x:Name="PetReviveCheck"  Classes="legacy-check" Tag="reviveGrowthFellow"           IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <CheckBox x:Name="PetSummonCheck"  Classes="legacy-check" Tag="autoSummonGrowthFellow"       IsCheckedChanged="Check_Changed" FontSize="11.5" />
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>

      <!-- Column 2 (Right) -->
      <StackPanel Grid.Column="2" Spacing="10">
        <!-- Back to Town Card -->
        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Back to Town" Classes="section-header-text" />
            </Border>
            <StackPanel Grid.Row="1" Margin="12,8" Spacing="2">
              <ItemsControl x:Name="BackToTownList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="protection:CheckRow">
                    <CheckBox Content="{Binding Label}" IsChecked="{Binding Enabled}" Classes="legacy-check" Margin="0,0" FontSize="11.5" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Stat Points Card -->
        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Stat Points" Classes="section-header-text" />
            </Border>
            <StackPanel Grid.Row="1" Margin="12,10" Spacing="8">
              <CheckBox x:Name="AutoStatCheck" Classes="legacy-check" Tag="statPointsAutoEnabled" IsCheckedChanged="Check_Changed" FontSize="11.5" />
              <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                <TextBlock Grid.Column="0" Text="Increase INT" Classes="label" VerticalAlignment="Center" FontSize="11.5" />
                <TextBox   Grid.Column="1" x:Name="IncIntBox" Width="50" Height="26" Classes="field" TextAlignment="Center" Tag="increaseInt" TextChanged="NumBox_Changed" FontSize="11.5" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                <TextBlock Grid.Column="0" Text="Increase STR" Classes="label" VerticalAlignment="Center" FontSize="11.5" />
                <TextBox   Grid.Column="1" x:Name="IncStrBox" Width="50" Height="26" Classes="field" TextAlignment="Center" Tag="increaseStr" TextChanged="NumBox_Changed" FontSize="11.5" />
              </Grid>
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>

    </Grid>
  </ScrollViewer>
</UserControl>
