<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.Features.Inventory.InventoryFeatureView">

  <Grid RowDefinitions="Auto,*">
    <!-- Top Tabs (Scrollable pills) -->
    <controls:TabStrip x:Name="MainTabs" Grid.Row="0" Margin="0,0,0,12" />

    <!-- Main Content Area -->
    <Border Grid.Row="1" Classes="section-card">
      <Grid RowDefinitions="Auto,*,Auto">
        <!-- List Header -->
        <Border Grid.Row="0" Classes="section-header">
           <TextBlock Text="Inventory list" Classes="section-header-text" />
        </Border>

        <!-- The List -->
        <Grid Grid.Row="1" Margin="16,12">
          <DataGrid x:Name="InventoryGrid" 
                    ItemsSource="{Binding Items}"
                    AutoGenerateColumns="False" 
                    IsReadOnly="True"
                    Background="Transparent"
                    BorderThickness="1"
                    BorderBrush="#1E293B"
                    CornerRadius="8"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="#1E293B"
                    RowHeight="42">
            <DataGrid.Styles>
              <Style Selector="DataGridRow">
                <Setter Property="ContextMenu">
                  <Setter.Value>
                    <ContextMenu>
                      <MenuItem Header="Use" Click="OnUseClick" IsVisible="{Binding CanUse}" />
                      <MenuItem Header="Drop" Click="OnDropClick" IsVisible="{Binding CanDrop}" />
                      <Separator IsVisible="{Binding IsReverseReturnScroll}" />
                      <MenuItem Header="Move to last death position" Click="OnReverseDeathClick" IsVisible="{Binding IsReverseReturnScroll}" />
                      <MenuItem Header="Move to last recall position" Click="OnReverseRecallClick" IsVisible="{Binding IsReverseReturnScroll}" />
                      <MenuItem Header="Select Map Location" x:Name="MapLocationSubMenu" IsVisible="{Binding IsReverseReturnScroll}" Loaded="OnMapSubMenuLoaded">
                        <!-- Populated in code-behind -->
                      </MenuItem>
                      <Separator />
                      <MenuItem Header="Use item at training place" Click="OnToggleTrainplaceClick" />
                      <MenuItem Header="Auto use according to purpose" Click="OnToggleAutoUseClick" />
                    </ContextMenu>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
              <DataGridTextColumn Header="SLOT" Binding="{Binding Slot}" Width="60" />
              
              <DataGridTemplateColumn Header="NAME" Width="*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="8,0">
                      <Image Width="24" Height="24" Source="{Binding IconBitmap}" Stretch="Uniform" />
                      <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="#EEF4FF" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="AMOUNT" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Amount}" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="OPT" Width="60">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding OptDisplay}" 
                               Foreground="{Binding OptColor}" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="16,0,16,16" ColumnDefinitions="Auto,*,Auto,12,Auto">
           <!-- Free Slots Indicator -->
           <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
             <Grid Width="24" Height="24" Margin="0,0,8,0">
               <Ellipse Stroke="#10B981" StrokeThickness="1.5" />
               <TextBlock x:Name="FreeSlotCount" Text="0" Foreground="#10B981" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
             </Grid>
             <TextBlock x:Name="FreeSlotText" Text="0 free" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" FontSize="13" />
           </StackPanel>

           <!-- Sort Controls (Only visible on Inventory tab) -->
           <StackPanel x:Name="SortPanel" Grid.Column="2" Orientation="Horizontal" Spacing="12">
             <StackPanel Orientation="Horizontal" Spacing="8">
               <ToggleSwitch x:Name="AutoSortCheck" OnContent="" OffContent="" VerticalAlignment="Center" Padding="0" Tag="autoSort" IsCheckedChanged="AutoSort_Changed" />
               <TextBlock Text="Auto sort" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
             </StackPanel>
           </StackPanel>
           
           <Button x:Name="SortBtn" Grid.Column="4" Classes="btn blue" Content="Sort" Padding="20,0" Height="32" Click="Sort_Click" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
