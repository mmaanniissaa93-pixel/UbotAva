<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="UBot.Avalonia.Features.Logging.LogFeatureView">

  <Grid RowDefinitions="Auto,Auto,*">
    <!-- Header: Title + Clear Button -->
    <Border Grid.Row="0" Classes="section-card">
      <Border Classes="section-header">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Runtime Log" Classes="section-header-text" VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="Clear"
                  Classes="legacy-btn compact"
                  Click="ClearLogs_Click"/>
        </Grid>
      </Border>
    </Border>

    <!-- Filters Row -->
    <Border Grid.Row="1" Classes="section-card" Padding="8" Margin="0,6,0,0">
      <StackPanel Orientation="Vertical" Spacing="6">
        <!-- Search -->
        <TextBox x:Name="SearchTextBox"
                 Watermark="Search logs..."
                 TextChanged="OnSearchTextChanged"
                 Padding="6,4" FontSize="11"/>

        <!-- Toggles -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <CheckBox x:Name="ShowDebugToggle"
                    Content="Debug"
                    IsChecked="True"
                    Checked="OnShowDebugToggled"
                    Unchecked="OnShowDebugToggled"
                    Padding="4,2" FontSize="11"/>
          <CheckBox x:Name="ShowEntityToggle"
                    Content="Entity"
                    IsChecked="False"
                    Checked="OnShowEntityToggled"
                    Unchecked="OnShowEntityToggled"
                    Padding="4,2" FontSize="11"/>
          <CheckBox x:Name="ShowPerfToggle"
                    Content="Perf"
                    IsChecked="False"
                    Checked="OnShowPerfToggled"
                    Unchecked="OnShowPerfToggled"
                    Padding="4,2" FontSize="11"/>
          <CheckBox x:Name="ShowProtocolToggle"
                    Content="Protocol"
                    IsChecked="False"
                    Checked="OnShowProtocolToggled"
                    Unchecked="OnShowProtocolToggled"
                    Padding="4,2" FontSize="11"/>
          <CheckBox x:Name="ShowErrorsOnlyToggle"
                    Content="Errors Only"
                    IsChecked="False"
                    Checked="OnShowErrorsOnlyToggled"
                    Unchecked="OnShowErrorsOnlyToggled"
                    Padding="4,2" FontSize="11"/>
          <CheckBox x:Name="PauseAutoscrollToggle"
                    Content="Pause Scroll"
                    IsChecked="False"
                    Checked="OnPauseAutoscrollToggled"
                    Unchecked="OnPauseAutoscrollToggled"
                    Padding="4,2" FontSize="11"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Log Viewer -->
    <Border Grid.Row="2" Classes="log-board" Padding="6" Margin="0,6,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="LogItems">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding .}"
                         FontFamily="Consolas"
                         FontSize="11.5"
                         Margin="6,1"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
