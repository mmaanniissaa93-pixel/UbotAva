<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="UBot.Avalonia.Features.CommandCenter.CommandCenterFeatureView">
  <Border Classes="section-card" Padding="16">
    <StackPanel Spacing="10">
      <TextBlock Text="Command Center opens in a popup window." Classes="label" />
      <Button x:Name="OpenPopupBtn" Classes="btn blue" Content="Open Command Center" Width="220" />
    </StackPanel>
  </Border>
</UserControl>
