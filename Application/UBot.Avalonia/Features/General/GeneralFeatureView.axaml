<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ctrls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.Features.General.GeneralFeatureView">

  <UserControl.Styles>
    <Style Selector="CheckBox.check.general-compact">
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="RadioButton.general-compact">
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.compact-label">
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock.compact-unit">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <StackPanel Spacing="8">

    <Border Classes="section-card">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="section-header">
          <TextBlock Text="SRO Client Path" Classes="section-header-text"/>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,170,Auto" Margin="14,10,14,12">
          <TextBox x:Name="SroBox"
                   Grid.Column="0"
                   Classes="field"
                   Watermark="C:\Path\sro_client.exe"
                   TextChanged="SroBox_Changed"
                   LostFocus="SroBox_LostFocus"/>

          <ctrls:CustomSelect x:Name="ClientTypeSelect"
                              Grid.Column="1"
                              Placeholder="Client Type"
                              MinWidth="145"
                              Margin="8,0,0,0"/>

          <Button Grid.Column="2"
                  Classes="browse-btn"
                  Content="..."
                  Width="32"
                  ToolTip.Tip="Browse"
                  Margin="8,0,0,0"
                  Click="BrowseSro_Click"/>
        </Grid>
      </Grid>
    </Border>

    <Grid ColumnDefinitions="1.08*,0.92*">

      <Border Grid.Column="0" Classes="section-card">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="section-header">
            <TextBlock Text="Automated Login" Classes="section-header-text"/>
          </Border>

          <StackPanel Grid.Row="1" Spacing="5" Margin="14,10,14,12">

            <Grid ColumnDefinitions="80,*,88">
              <TextBlock Grid.Column="0" Text="Account" Classes="label compact-label"/>
              <ctrls:CustomSelect x:Name="AccountSelect" Grid.Column="1" Placeholder="Not Selected" Margin="6,0"/>
              <Button Grid.Column="2" Classes="btn" Content="Setup" Click="AccountSetup_Click"/>
            </Grid>

            <Grid ColumnDefinitions="80,*">
              <TextBlock Grid.Column="0" Text="Player" Classes="label compact-label"/>
              <ctrls:CustomSelect x:Name="CharacterSelect" Grid.Column="1" Placeholder="Not Selected" Margin="6,0,0,0"/>
            </Grid>

            <Grid ColumnDefinitions="80,*">
              <TextBlock Grid.Column="0" Text="Captcha" Classes="label compact-label"/>
              <TextBox Grid.Column="1" x:Name="CaptchaBox" Classes="field" LostFocus="Captcha_LostFocus" Margin="6,0,0,0"/>
            </Grid>

            <Border Classes="section-separator" Margin="0,6,0,4"/>

            <Grid ColumnDefinitions="*,*,*" Margin="0,2,0,0">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Login Flow" Classes="group-caption"/>
                <CheckBox x:Name="EnableAutoLoginCheck" Classes="check general-compact" Content="Enable automated login"
                          IsCheckedChanged="Check_Changed" Tag="enableAutomatedLogin"/>
                <CheckBox x:Name="EnableStaticCaptchaCheck" Classes="check general-compact" Content="Enable static captcha"
                          IsCheckedChanged="Check_Changed" Tag="enableStaticCaptcha"/>
                <CheckBox x:Name="EnableLoginDelayCheck" Classes="check general-compact" Content="Enable login delay"
                          IsCheckedChanged="Check_Changed" Tag="enableLoginDelay"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="Recovery" Classes="group-caption"/>
                <CheckBox x:Name="WaitAfterDcCheck" Classes="check general-compact" Content="Wait after DC"
                          IsCheckedChanged="Check_Changed" Tag="enableWaitAfterDc"/>
                <CheckBox x:Name="AutoStartBotCheck" Classes="check general-compact" Content="Auto start bot"
                          IsCheckedChanged="Check_Changed" Tag="autoStartBot"/>
                <CheckBox x:Name="UseReturnScrollCheck" Classes="check general-compact" Content="Use return scroll"
                          IsCheckedChanged="Check_Changed" Tag="useReturnScroll"/>
              </StackPanel>

              <StackPanel Grid.Column="2" Spacing="2">
                <TextBlock Text="Character Flow" Classes="group-caption"/>
                <CheckBox x:Name="AutoCharSelectCheck" Classes="check general-compact" Content="Auto Char Select"
                          IsCheckedChanged="Check_Changed" Tag="autoCharSelect"/>
                <CheckBox x:Name="AutoHideClientCheck" Classes="check general-compact" Content="Auto Hide Client"
                          IsCheckedChanged="Check_Changed" Tag="autoHideClient"/>
                <RadioButton x:Name="FirstFoundRadio"
                             Content="First Found"
                             GroupName="charSelect"
                             Checked="RadioFirstFound_Checked"
                             Classes="general-compact"/>
                <RadioButton x:Name="HighestLevelRadio"
                             Content="Highest Level"
                             GroupName="charSelect"
                             Checked="RadioHighest_Checked"
                             Classes="general-compact"/>
              </StackPanel>
            </Grid>

            <TextBlock Classes="hint"
                       Text="Please use this only if the captcha never changes."
                       TextWrapping="Wrap"
                       Margin="0,0,0,2"/>

            <Border Classes="section-separator" Margin="0,6,0,4"/>

            <Grid ColumnDefinitions="84,64,Auto,14,84,64,Auto" VerticalAlignment="Center">
              <TextBlock Grid.Column="0" Text="Login delay" Classes="label compact-label" VerticalAlignment="Center"/>
              <TextBox Grid.Column="1" x:Name="LoginDelayBox" Classes="compact-num"
                       TextChanged="NumBox_Changed" LostFocus="NumBox_LostFocus" Tag="loginDelay"/>
              <TextBlock Grid.Column="2" Text="sec" Classes="compact-unit"/>

              <TextBlock Grid.Column="4" Text="Wait after DC" Classes="label compact-label" VerticalAlignment="Center"/>
              <TextBox Grid.Column="5" x:Name="WaitAfterDcBox" Classes="compact-num"
                       TextChanged="NumBox_Changed" LostFocus="NumBox_LostFocus" Tag="waitAfterDc"/>
              <TextBlock Grid.Column="6" Text="min" Classes="compact-unit"/>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>

      <StackPanel Grid.Column="1" Spacing="8">

        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Client Settings / Bot Settings" Classes="section-header-text"/>
            </Border>

            <StackPanel Grid.Row="1" Spacing="2" Margin="12,10,12,12">
              <CheckBox x:Name="StayConnectedCheck" Classes="check general-compact"
                        Content="Stay connected if client exits unexpectedly"
                        IsCheckedChanged="Check_Changed" Tag="stayConnectedAfterClientExit"/>
              <CheckBox x:Name="MoveToTrayCheck" Classes="check general-compact"
                        Content="Move bot to system tray when minimized"
                        IsCheckedChanged="Check_Changed" Tag="moveToTrayOnMinimize"/>
              <Border Classes="section-separator" Margin="0,4,0,2"/>
              <TextBlock Classes="hint"
                         Text="If the client exits due to a crash, the bot will automatically switch."
                         Margin="0,2,0,0"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Server Pending" Classes="section-header-text"/>
            </Border>

            <StackPanel Grid.Row="1" Spacing="2" Margin="12,10,12,12">
              <CheckBox x:Name="AutoHidePendingCheck" Classes="check general-compact" Content="Auto hide the pending window"
                        IsCheckedChanged="Check_Changed" Tag="autoHidePendingWindow"/>
              <CheckBox x:Name="EnablePendingLogsCheck" Classes="check general-compact" Content="Enable pending queue logs"
                        IsCheckedChanged="Check_Changed" Tag="enablePendingQueueLogs"/>

              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,2,0,0">
                <CheckBox x:Name="EnableQueueNotifCheck" Classes="check general-compact"
                          Content="Notify on"
                          IsCheckedChanged="Check_Changed" Tag="enableQueueNotification"/>
                <TextBox x:Name="PeopleLeftBox" Classes="compact-num"
                         TextChanged="NumBox_Changed" LostFocus="NumBox_LostFocus" Tag="queuePeopleLeft"/>
                <TextBlock Text="people left" Classes="compact-unit"/>
              </StackPanel>

              <Border Classes="section-separator" Margin="0,4,0,2"/>

              <Button Classes="btn"
                      Content="Toggle Pending Window"
                      HorizontalAlignment="Stretch"
                      Margin="0,4,0,0"
                      Click="TogglePendingWindow_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Classes="section-card">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="section-header">
              <TextBlock Text="Sound Notifications" Classes="section-header-text"/>
            </Border>

            <StackPanel Grid.Row="1" Spacing="2" Margin="12,10,12,12">
              <Button Classes="btn"
                      Content="Open Settings..."
                      HorizontalAlignment="Stretch"
                      Click="OpenSoundSettings_Click"/>
            </StackPanel>
          </Grid>
        </Border>

      </StackPanel>
    </Grid>
  </StackPanel>
</UserControl>
