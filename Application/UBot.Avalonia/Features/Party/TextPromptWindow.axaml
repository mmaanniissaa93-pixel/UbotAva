<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="UBot.Avalonia.Features.Party.TextPromptWindow"
  Title="Input"
  Width="430"
  Height="210"
  MinWidth="410"
  MinHeight="190"
  CanResize="False"
  WindowStartupLocation="CenterOwner"
  Background="{DynamicResource PanelBrush}">
  <Border Margin="10" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
    <Grid RowDefinitions="Auto,Auto,Auto">
      <TextBlock x:Name="PromptLabel" Grid.Row="0" FontSize="16" FontWeight="SemiBold"/>
      <TextBox x:Name="InputBox" Grid.Row="1" Classes="field" Margin="0,10,0,0"/>
      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,10,0,0">
        <Button Grid.Column="1" Classes="btn blue" Content="OK" Width="96" Click="Ok_Click"/>
        <Button Grid.Column="2" Classes="btn" Content="Cancel" Width="96" Click="Cancel_Click" Margin="8,0,0,0"/>
      </Grid>
    </Grid>
  </Border>
</Window>
