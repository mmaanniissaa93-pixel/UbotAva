<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.Features.Skills.SkillsFeatureView">
  
  <Grid ColumnDefinitions="330,*" Margin="0,0,0,12" VerticalAlignment="Stretch">

    <!-- Left Sidebar: Skill Selection -->
    <Border Grid.Column="0" Background="{DynamicResource CardSurfaceBrush}" CornerRadius="12" Padding="0" Margin="0,0,12,0" ClipToBounds="True">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Sidebar Header / Tabs -->
        <Border Grid.Row="0" Background="{DynamicResource SectionHeaderBrush}" Padding="4">
          <controls:TabStrip x:Name="LeftTabs" />
        </Border>

        <!-- Search Bar (Placeholder UI) -->
        <Border Grid.Row="1" Background="{DynamicResource CardSurfaceBrush}" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SectionSeparatorBrush}">
          <TextBox Watermark="Search skills..." Classes="field" Height="32" Padding="8,4" FontSize="12" />
        </Border>

        <!-- Skill Lists Area (Internal Scroll) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
          <Border Padding="12">
            <Panel>
              <Border x:Name="PlayerSkillsPanel">
                <Grid RowDefinitions="*">
                  <ListBox x:Name="PlayerSkillsList" Background="Transparent" BorderThickness="0" Padding="0">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0,0,0,6" />
                      <Setter Property="Background" Value="Transparent" />
                      <Setter Property="CornerRadius" Value="8" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="{DynamicResource TabBtnHoverBgBrush}" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                      <Setter Property="Background" Value="{DynamicResource TabBtnActiveBgBrush}" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="10,8" Margin="0" Background="Transparent">
                        <Grid ColumnDefinitions="36,12,*">
                          <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource FieldBgBrush}" CornerRadius="6" ClipToBounds="True">
                            <Image Source="{Binding IconBitmap}" Width="36" Height="36" RenderOptions.BitmapInterpolationMode="HighQuality" />
                          </Border>
                          <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Display}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Id}" FontSize="10" Foreground="{DynamicResource TextDimBrush}" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                  </ListBox>
                  <TextBlock x:Name="PlayerSkillsEmptyHint"
                             Text="No skills found for current filters."
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Classes="hint"
                             IsHitTestVisible="False"
                             IsVisible="False" />
                </Grid>
              </Border>

              <Border x:Name="ActiveBuffsPanel" IsVisible="False">
                <Grid RowDefinitions="*">
                  <ListBox x:Name="ActiveBuffsList" Background="Transparent" BorderThickness="0" Padding="0">
                    <!-- Similar template for Buffs -->
                  </ListBox>
                  <TextBlock x:Name="ActiveBuffsEmptyHint"
                             Text="No active buffs."
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Classes="hint"
                             IsHitTestVisible="False"
                             IsVisible="False" />
                </Grid>
              </Border>
            </Panel>
          </Border>
        </ScrollViewer>

        <!-- Active Features Toolbar -->
        <Border Grid.Row="3" Background="{DynamicResource SectionHeaderBrush}" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SectionSeparatorBrush}">
          <Grid ColumnDefinitions="*,*">
            <CheckBox Grid.Column="0" x:Name="EnableAttacksCheck" Content="Attacks" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="enableAttacks" HorizontalAlignment="Center" />
            <CheckBox Grid.Column="1" x:Name="EnableBuffsCheck" Content="Buffs" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="enableBuffs" HorizontalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <!-- Main Content Area -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Background="{DynamicResource CardSurfaceBrush}" CornerRadius="12" Padding="4" Margin="0,0,0,12">
        <controls:TabStrip x:Name="MainTabs" />
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
          <!-- General Setup Tab Content -->
          <StackPanel x:Name="GeneralSetupPanel" Spacing="12">
            <!-- Attacking Skills Card -->
            <Border Classes="section-card">
              <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Classes="section-header">
                  <TextBlock Text="Attacking Skills" Classes="section-header-text" />
                </Border>
                <StackPanel Grid.Row="1" Margin="12,10" Spacing="10">
                  <Grid ColumnDefinitions="*,10,Auto">
                    <Border Grid.Column="0" Background="{DynamicResource FieldBgBrush}" CornerRadius="8" Height="170" Padding="4">
                      <ListBox x:Name="AttackSkillsList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="32,10,*,Auto" Margin="0,1">
                              <Image Grid.Column="0" Source="{Binding IconBitmap}" Width="22" Height="22" />
                              <TextBlock Grid.Column="2" Text="{Binding Display}" VerticalAlignment="Center" FontSize="11.5" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Border>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <Button Classes="btn blue" Width="34" Height="34" Content="+" Click="AddAttackSkill_Click" Padding="0" FontSize="16" />
                      <Button Classes="btn red" Width="34" Height="34" Content="×" Click="RemoveAttackSkill_Click" Padding="0" FontSize="16" />
                      <Button Classes="btn" Width="34" Height="30" Content="▲" Click="MoveAttackUp_Click" Padding="0" />
                      <Button Classes="btn" Width="34" Height="30" Content="▼" Click="MoveAttackDown_Click" Padding="0" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,180,14,Auto,14,Auto,*" VerticalAlignment="Center" MinHeight="32">
                    <TextBlock Grid.Column="0"
                               Text="Type"
                               Classes="label"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="12" />
                    <controls:CustomSelect Grid.Column="1" x:Name="AttackTypeSelect" Height="32" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="3"
                              x:Name="UseInOrderCheck"
                              Content="In order"
                              Classes="legacy-check"
                              IsCheckedChanged="SimpleCheck_Changed"
                              Tag="useSkillsInOrder"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="0"
                              MinHeight="0" />
                    <CheckBox Grid.Column="5"
                              x:Name="NoAttackCheck"
                              Content="No attack"
                              Classes="legacy-check"
                              IsCheckedChanged="SimpleCheck_Changed"
                              Tag="noAttack"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="0"
                              MinHeight="0" />
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Buffing Skills Card -->
            <Border Classes="section-card">
              <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Classes="section-header">
                  <TextBlock Text="Buffing Skills" Classes="section-header-text" />
                </Border>
                <StackPanel Grid.Row="1" Margin="12,10" Spacing="10">
                  <Grid ColumnDefinitions="*,10,Auto">
                    <Border Grid.Column="0" Background="{DynamicResource FieldBgBrush}" CornerRadius="8" Height="170" Padding="4">
                      <ListBox x:Name="BuffSkillsList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="32,10,*,Auto" Margin="0,1">
                              <Image Grid.Column="0" Source="{Binding IconBitmap}" Width="22" Height="22" />
                              <TextBlock Grid.Column="2" Text="{Binding Display}" VerticalAlignment="Center" FontSize="11.5" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Border>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <Button Classes="btn blue" Width="34" Height="34" Content="+" Click="AddBuffSkill_Click" Padding="0" FontSize="16" />
                      <Button Classes="btn red" Width="34" Height="34" Content="×" Click="RemoveBuffSkill_Click" Padding="0" FontSize="16" />
                      <Button Classes="btn" Width="34" Height="30" Content="▲" Click="MoveBuffUp_Click" Padding="0" />
                      <Button Classes="btn" Width="34" Height="30" Content="▼" Click="MoveBuffDown_Click" Padding="0" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,180">
                    <TextBlock Grid.Column="0" Text="Imbue" Classes="label" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" />
                    <controls:CustomSelect Grid.Column="1" x:Name="ImbueSkillSelect" Height="32" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>

          <!-- Advanced Setup Tab Content -->
          <StackPanel x:Name="AdvancedSetupPanel" Spacing="12" IsVisible="False">
            <!-- Automated Resurrection Card -->
            <Border Classes="section-card">
              <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Classes="section-header">
                  <TextBlock Text="Automated Resurrection" Classes="section-header-text" />
                </Border>
                <StackPanel Grid.Row="1" Margin="16" Spacing="12">
                  <Grid ColumnDefinitions="Auto,260">
                    <TextBlock Grid.Column="0" Text="Resurrection skill" Classes="label" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <controls:CustomSelect Grid.Column="1" x:Name="ResurrectionSkillSelect" />
                  </Grid>

                  <Grid ColumnDefinitions="*,12,*">
                    <StackPanel Grid.Column="0" Spacing="8">
                      <CheckBox x:Name="AcceptResurrectionCheck" Content="Auto accept resurrection" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="acceptResurrection" />
                      <CheckBox x:Name="ResurrectPartyCheck" Content="Auto resurrect party" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="resurrectParty" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="8">
                      <Grid ColumnDefinitions="*,8,50,8,Auto">
                        <TextBlock Grid.Column="0" Text="Resurrection Delay" Classes="label" VerticalAlignment="Center" FontSize="11" />
                        <TextBox Grid.Column="2" x:Name="ResDelayBox" Classes="field" TextAlignment="Center" TextChanged="NumericBox_Changed" Tag="resDelay" />
                        <TextBlock Grid.Column="4" Text="sec" Classes="label" VerticalAlignment="Center" Opacity="0.5" />
                      </Grid>
                      <Grid ColumnDefinitions="*,8,50,8,Auto">
                        <TextBlock Grid.Column="0" Text="Resurrection Radius" Classes="label" VerticalAlignment="Center" FontSize="11" />
                        <TextBox Grid.Column="2" x:Name="ResRadiusBox" Classes="field" TextAlignment="Center" TextChanged="NumericBox_Changed" Tag="resRadius" />
                        <TextBlock Grid.Column="4" Text="m" Classes="label" VerticalAlignment="Center" Opacity="0.5" />
                      </Grid>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Advanced Buff & Mastery Card -->
            <Grid ColumnDefinitions="*,12,*">
              <Border Grid.Column="0" Classes="section-card">
                <Grid RowDefinitions="Auto,*">
                  <Border Grid.Row="0" Classes="section-header">
                    <TextBlock Text="Buff Configuration" Classes="section-header-text" />
                  </Border>
                  <StackPanel Grid.Row="1" Margin="16" Spacing="10">
                    <CheckBox x:Name="CastBuffsInTownsCheck" Content="Cast in towns" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="castBuffsInTowns" />
                    <CheckBox x:Name="CastBuffsWalkBackCheck" Content="Cast while walk-back" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="castBuffsDuringWalkBack" />
                    <CheckBox x:Name="CastBuffsBetweenAttacksCheck" Content="Cast between attacks" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="castBuffsBetweenAttacks" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Column="2" Classes="section-card">
                <Grid RowDefinitions="Auto,*">
                  <Border Grid.Row="0" Classes="section-header">
                    <TextBlock Text="Mastery Update" Classes="section-header-text" />
                  </Border>
                  <StackPanel Grid.Row="1" Margin="16" Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto,50">
                      <CheckBox Grid.Column="0" x:Name="LearnMasteryCheck" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="learnMastery" VerticalAlignment="Center" />
                      <controls:CustomSelect Grid.Column="1" x:Name="MasterySelect" Margin="0,0,8,0" />
                      <TextBlock Grid.Column="2" Text="Gap" Classes="label" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11" />
                      <TextBox Grid.Column="3" x:Name="MasteryGapBox" Classes="field" TextAlignment="Center" TextChanged="NumericBox_Changed" Tag="masteryGap" />
                    </Grid>
                    <CheckBox x:Name="LearnMasteryStoppedCheck" Content="Learn if bot is stopped" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="learnMasteryBotStopped" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <!-- Extra Settings Card -->
            <Border Classes="section-card">
              <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Classes="section-header">
                  <TextBlock Text="Advanced Setup" Classes="section-header-text" />
                </Border>
                <StackPanel Grid.Row="1" Margin="16" Spacing="10">
                  <CheckBox x:Name="WarlockModeCheck" Content="Warlock Mode: Change target after 2 DoTs" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="warlockMode" />
                  <CheckBox x:Name="UseDefaultAttackCheck" Content="Use normal attack if no skill is available" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="useDefaultAttack" />

                  <Grid ColumnDefinitions="Auto,200">
                    <CheckBox Grid.Column="0" x:Name="UseTeleportSkillCheck" Content="Use teleport skill" Classes="legacy-check" IsCheckedChanged="SimpleCheck_Changed" Tag="useTeleportSkill" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <controls:CustomSelect Grid.Column="1" x:Name="TeleportSkillSelect" />
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
