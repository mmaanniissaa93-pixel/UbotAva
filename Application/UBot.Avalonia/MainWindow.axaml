<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
  xmlns:ctrls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.MainWindow"
  Title="UBot"
  Width="1280" Height="760"
  MinWidth="960" MinHeight="600"
  Background="{DynamicResource AppBg}"
  ExtendClientAreaToDecorationsHint="True"
  ExtendClientAreaChromeHints="NoChrome"
  WindowStartupLocation="CenterScreen">

  <Panel>

    <!-- Drag zone -->
    <Border Height="36" VerticalAlignment="Top" IsHitTestVisible="True"
            Background="Transparent" ZIndex="30"
            PointerPressed="DragZone_PointerPressed"/>

    <!-- App shell: sidebar | workspace -->
    <Grid ColumnDefinitions="220,*"
          Margin="8,36,8,8">

      <!-- â•â•â•â•â•â•â•â•â•â• SIDEBAR â•â•â•â•â•â•â•â•â•â• -->
      <Border Grid.Column="0"
              Background="{DynamicResource SidebarBrush}"
              BorderBrush="{DynamicResource StrokeSoftBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource RadiusLg}">
        <Grid RowDefinitions="Auto,*" Margin="8">

          <!-- Banner -->
          <Border Grid.Row="0" CornerRadius="10" ClipToBounds="True"
                  Height="70" Margin="0,0,0,8">
            <Image x:Name="BannerImage" Stretch="UniformToFill" HorizontalAlignment="Left"/>
          </Border>

          <!-- Nav -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="NavPanel" Spacing="2"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- â•â•â•â•â•â•â•â•â•â• WORKSPACE â•â•â•â•â•â•â•â•â•â• -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*">

        <!-- â”€â”€ TOPBAR â”€â”€ -->
        <Border Grid.Row="0"
                Background="{DynamicResource TopbarBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="10,8">

          <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Left: status + lang -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

              <!-- Status chip -->
              <Border x:Name="StatusChipBorder" Classes="status-stopped">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{DynamicResource DangerBrush}"/>
                  <TextBlock x:Name="StatusText" FontSize="10" FontWeight="Bold"
                             Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>

              <!-- Lang + theme pill -->
              <Border CornerRadius="999" BorderBrush="{DynamicResource StrokeSoftBrush}"
                      BorderThickness="1" Background="#08FFFFFF" Padding="2">
                <StackPanel Orientation="Horizontal" Spacing="1">
                  <Button x:Name="BtnEn" Classes="lang-btn" Content="EN" Click="BtnEn_Click"/>
                  <Button x:Name="BtnTr" Classes="lang-btn" Content="TR" Click="BtnTr_Click"/>
                  <Button x:Name="BtnTheme" Classes="lang-btn" Width="26"
                          Click="BtnTheme_Click" ToolTip.Tip="Toggle theme">
                    <shapes:Path x:Name="ThemeIcon"
                      Width="12" Height="12" Stretch="Uniform"
                      Stroke="{DynamicResource TextDimBrush}" StrokeThickness="1.4"
                      Data="M12,3 A9,9 0 1,0 12,21 A9,9 0 0,0 12,3 Z"/>
                  </Button>
                </StackPanel>
              </Border>

            </StackPanel>

            <!-- Center: profile + character -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
              <Border Classes="topbar-pill">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <shapes:Path Width="13" Height="13" Stretch="Uniform"
                    Stroke="#64F3D0" StrokeThickness="1.4"
                    Data="M20,21 A8,8 0 1,0 4,21 M12,13 A4,4 0 1,0 12,5 A4,4 0 0,0 12,13"/>
                  <TextBlock x:Name="ProfileLabel" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                             MaxWidth="130" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>

              <Border x:Name="CharPill" Classes="topbar-pill">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <ContentControl x:Name="CharIcon" Width="13" Height="13"/>
                  <TextBlock x:Name="CharLabel" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                             MaxWidth="160" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Right: selects + buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <ctrls:CustomSelect x:Name="DivisionSelect" Placeholder="Division" MinWidth="120"/>
              <ctrls:CustomSelect x:Name="GatewaySelect"  Placeholder="Server..."  MinWidth="130"/>

              <Button x:Name="BtnDisconnect" Classes="btn ghost" Click="BtnDisconnect_Click">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <shapes:Path Width="13" Height="13" Stretch="Uniform"
                    Stroke="#FFD48A" StrokeThickness="1.4"
                    Data="M18.36,6.64 A9,9 0 1,1 5.64,6.64 M12,2 L12,12"/>
                  <TextBlock x:Name="LblDisconnect" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnStart" Classes="btn start" Click="BtnStart_Click">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <shapes:Path Width="11" Height="11" Stretch="Uniform"
                    Fill="#042E1E" Data="M5,3 L19,12 L5,21 Z"/>
                  <TextBlock x:Name="LblStart" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnStop" Classes="btn danger" Click="BtnStop_Click">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <shapes:Path Width="11" Height="11" Stretch="Uniform"
                    Fill="#FFE4E4" Data="M3,3 L21,3 L21,21 L3,21 Z"/>
                  <TextBlock x:Name="LblStop" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnSave" Classes="btn icon" Click="BtnSave_Click"
                      ToolTip.Tip="Save config">
                <shapes:Path Width="13" Height="13" Stretch="Uniform"
                  Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.4"
                  Data="M19,21 L5,21 A2,2 0 0,1 3,19 L3,5 A2,2 0 0,1 5,3 L16,3 L21,8 L21,19 A2,2 0 0,1 19,21 Z M17,21 L17,13 L7,13 L7,21 M7,3 L7,8 L15,8"/>
              </Button>
            </StackPanel>

          </Grid>
        </Border>

        <!-- â”€â”€ CONTENT AREA â”€â”€ -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource RadiusLg}"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,*">

            <!-- Metric cards row (Level, HP, MP, EXP) â€” always visible -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,*,*,*"
                 
                  Margin="14,14,14,0">

              <!-- LEVEL -->
              <Border Grid.Column="0" Classes="metric-card">
                <StackPanel>
                  <TextBlock Text="LEVEL" Classes="metric-label"/>
                  <TextBlock x:Name="MetricLevel" Classes="metric-value green"/>
                </StackPanel>
              </Border>

              <!-- HP -->
              <Border Grid.Column="1" Classes="metric-card">
                <StackPanel Spacing="6">
                  <TextBlock Text="HP" Classes="metric-label"/>
                  <TextBlock x:Name="MetricHp" Classes="metric-value blue"/>
                  <Grid>
                    <Border Background="#1878A0CC" CornerRadius="999" Height="4"/>
                    <Border x:Name="HpBar" Background="{DynamicResource MetricBlueBrush}"
                            CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- MP -->
              <Border Grid.Column="2" Classes="metric-card">
                <StackPanel Spacing="6">
                  <TextBlock Text="MP" Classes="metric-label"/>
                  <TextBlock x:Name="MetricMp" Classes="metric-value amber"/>
                  <Grid>
                    <Border Background="#18F59E0B" CornerRadius="999" Height="4"/>
                    <Border x:Name="MpBar" Background="{DynamicResource MetricAmberBrush}"
                            CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- EXP -->
              <Border Grid.Column="3" Classes="metric-card">
                <StackPanel Spacing="6">
                  <TextBlock Text="EXP" Classes="metric-label"/>
                  <TextBlock x:Name="MetricExp" Classes="metric-value amber"/>
                  <Grid>
                    <Border Background="#18F59E0B" CornerRadius="999" Height="4"/>
                    <Border x:Name="ExpBar" Background="{DynamicResource MetricAmberBrush}"
                            CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                  </Grid>
                </StackPanel>
              </Border>

            </Grid>

            <!-- Feature view content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,10,14,14">
              <ContentControl x:Name="ContentHost"/>
            </ScrollViewer>

          </Grid>
        </Border>

      </Grid>
    </Grid>
  </Panel>
</Window>



