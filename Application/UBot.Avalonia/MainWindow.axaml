<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
  xmlns:ctrls="clr-namespace:UBot.Avalonia.Controls"
  x:Class="UBot.Avalonia.MainWindow"
  Title="UBot"
  Width="1440" Height="900"
  MinWidth="1440" MinHeight="900"
  MaxWidth="1440" MaxHeight="900"
  CanResize="False"
  Background="{DynamicResource AppBg}"
  ExtendClientAreaToDecorationsHint="True"
  ExtendClientAreaChromeHints="NoChrome"
  WindowStartupLocation="CenterScreen">

<Panel>

    <Border Height="36"
            VerticalAlignment="Top"
            IsHitTestVisible="True"
            Background="Transparent"
            ZIndex="30"
            PointerPressed="DragZone_PointerPressed"/>

    <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                ZIndex="50"
                Margin="0,0,4,0"
                Spacing="0">
      
      <!-- Hamburger Menu -->
      <Button Classes="window-btn" ToolTip.Tip="Menu" VerticalAlignment="Center">
        <shapes:Path Data="M3,6 L21,6 M3,12 L21,12 M3,18 L21,18" 
                     Stroke="White" 
                     StrokeThickness="2" 
                     Width="18" Height="18" 
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        <Button.Flyout>
          <MenuFlyout Placement="BottomEdgeAlignedRight">
            <MenuItem Header="File">
              <MenuItem Header="Select Profile..." Click="OnSelectProfileClick" />
              <MenuItem Header="Proxy Config" Click="OnProxyConfigClick" />
            </MenuItem>
            <MenuItem Header="Plugins" x:Name="PluginsMenu" />
            <MenuItem Header="Automation" x:Name="AutomationMenu" />
            <MenuItem Header="About" Click="OnAboutClick" />
          </MenuFlyout>
        </Button.Flyout>
      </Button>

      <Button Classes="window-btn" Click="MinimizeWindow_Click">
        <Grid Width="46" Height="36">
          <Border Width="18" Height="18" CornerRadius="4" Background="#22FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Path Data="M4,8 L14,8" Stroke="#FFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Grid>
      </Button>
      <Button Classes="window-btn close" Click="CloseWindow_Click">
        <Grid Width="46" Height="36">
          <Border Width="18" Height="18" CornerRadius="4" Background="#22FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Path Data="M5,5 L13,13 M13,5 L5,13" Stroke="#FFFFFF" StrokeThickness="1.8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Grid>
      </Button>
    </StackPanel>


    <Grid ColumnDefinitions="250,*"
          Margin="6,36,6,6">

      <Border Grid.Column="0"
              Classes="shell-card"
              Background="{DynamicResource SidebarBrush}">
        <Grid RowDefinitions="Auto,*" Margin="10">

          <Border Grid.Row="0"
                  CornerRadius="12"
                  ClipToBounds="True"
                  Height="78"
                  Margin="0,0,0,10"
                  BorderBrush="{DynamicResource StrokeSoftBrush}"
                  BorderThickness="1">
            <Image x:Name="BannerImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>
          </Border>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="NavPanel" Spacing="3"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="10,0,0,0">

        <Border Grid.Row="0"
                Background="{DynamicResource TopbarBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10,8">

          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">

            <!-- Row 0 Left: Status chip + language + theme -->
            <StackPanel Grid.Row="0" Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="7"
                        VerticalAlignment="Center">

              <Border x:Name="StatusChipBorder" Classes="status-stopped">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Ellipse x:Name="StatusPulseDot"
                           Width="7"
                           Height="7"
                           Fill="{DynamicResource AccentBrush}"
                           IsVisible="False"
                           Opacity="1"/>
                  <shapes:Path x:Name="StatusIcon" Width="11" Height="11" Stretch="Uniform"
                               StrokeThickness="1.6"
                               Data="M18,6 L6,18 M6,6 L18,18"/>
                  <TextBlock x:Name="StatusText"
                             FontSize="10.5"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource DangerBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>

              <Border CornerRadius="999"
                      BorderBrush="{DynamicResource StrokeSoftBrush}"
                      BorderThickness="1"
                      Background="#12FFFFFF"
                      Padding="3">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button x:Name="BtnEn" Classes="lang-btn active" Content="EN" Click="BtnEn_Click"/>
                  <Button x:Name="BtnTr" Classes="lang-btn" Content="TR" Click="BtnTr_Click"/>
                </StackPanel>
              </Border>

              <Button x:Name="BtnTheme"
                      Classes="lang-btn"
                      Width="26"
                      Click="BtnTheme_Click"
                      ToolTip.Tip="Toggle theme"
                      Background="#12FFFFFF">
                <shapes:Path x:Name="ThemeIcon"
                             Width="12"
                             Height="12"
                             Stretch="Uniform"
                             Stroke="{DynamicResource TextDimBrush}"
                             StrokeThickness="1.4"
                             Data="M12,3 C9.1,3 6.4,4.5 4.8,7 C3.2,9.5 3.2,12.5 4.8,15 C6.4,17.5 9.1,19 12,19 C16,19 19,16 19,12 A9,9 0 0,0 12,3 Z"/>
              </Button>
            </StackPanel>

            <!-- Row 0 Right: Selects + PRIMARY toggle + Save -->
            <StackPanel Grid.Row="0" Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
              <ctrls:CustomSelect x:Name="DivisionSelect" Placeholder="Aege" MinWidth="128"/>
              <ctrls:CustomSelect x:Name="GatewaySelect" Placeholder="Aege" MinWidth="128"/>

              <Button x:Name="BtnDisconnect" Classes="btn secondary" Click="BtnDisconnect_Click" Width="120">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <shapes:Path Width="11" Height="11" Stretch="Uniform"
                               Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.4"
                               Data="M18.36,6.64 A9,9 0 1,1 5.64,6.64 M12,2 L12,12"/>
                  <TextBlock x:Name="LblDisconnect" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <!-- Single primary Start/Stop toggle -->
              <Button x:Name="BtnToggle" Classes="btn primary go" Click="BtnToggle_Click" Width="130">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <shapes:Path x:Name="ToggleIcon" Width="13" Height="13" Stretch="Uniform"
                               Fill="#F0FFFFFF"
                               Data="M5,3 L19,12 L5,21 Z"/>
                  <TextBlock x:Name="LblToggle" Text="START" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnSave" Classes="btn icon" Click="BtnSave_Click" ToolTip.Tip="Save config">
                <shapes:Path Width="13" Height="13" Stretch="Uniform"
                             Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.4"
                             Data="M19,21 L5,21 A2,2 0 0,1 3,19 L3,5 A2,2 0 0,1 5,3 L16,3 L21,8 L21,19 A2,2 0 0,1 19,21 Z M17,21 L17,13 L7,13 L7,21 M7,3 L7,8 L15,8"/>
              </Button>
            </StackPanel>

            <!-- Row 1 Left: Profile + Character pills -->
            <StackPanel Grid.Row="1" Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="7"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center">
              <Border Classes="topbar-pill">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <shapes:Path Width="13" Height="13" Stretch="Uniform"
                               Stroke="#64F3D0" StrokeThickness="1.4"
                               Data="M20,21 A8,8 0 1,0 4,21 M12,13 A4,4 0 1,0 12,5 A4,4 0 0,0 12,13"/>
                  <TextBlock x:Name="ProfileLabel"
                             FontSize="11"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             MaxWidth="160"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>

              <Border x:Name="CharPill" Classes="topbar-pill">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <ContentControl x:Name="CharIcon" Width="13" Height="13"/>
                  <TextBlock x:Name="CharLabel"
                             FontSize="11"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             MaxWidth="200"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Row 1 Right: Secondary actions -->
            <StackPanel Grid.Row="1" Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="5"
                        Margin="8,8,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

              <Button x:Name="BtnStartClient" Classes="btn ghost-outline" Click="BtnStartClient_Click" Width="105">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <shapes:Path Width="10" Height="10" Stretch="Uniform"
                               Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.4"
                               Data="M5,3 L19,12 L5,21 Z"/>
                  <TextBlock x:Name="LblStartClient" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnGoClientless" Classes="btn ghost-outline" Click="BtnGoClientless_Click" Width="105">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <shapes:Path Width="10" Height="10" Stretch="Uniform"
                               Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.4"
                               Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 0,0 12,2"/>
                  <TextBlock x:Name="LblGoClientless" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button x:Name="BtnHideClient" Classes="btn ghost-outline" Click="BtnHideClient_Click" Width="105">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <shapes:Path Width="10" Height="10" Stretch="Uniform"
                               Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.4"
                               Data="M1,1 L23,23 M17.94,17.94 A10,10 0 0,1 12,20 C6,20 1,12 1,12 A18.5,18.5 0 0,1 5.06,7.06 M9.9,4.24 A9,9 0 0,1 12,4 C18,4 23,12 23,12 A18.5,18.5 0 0,1 20.49,15.68"/>
                  <TextBlock x:Name="LblHideClient" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>

          </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1"
                CornerRadius="16"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,*">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,*,*,*"
                  Margin="12,12,12,0">

              <Border Grid.Column="0" Classes="metric-card empty">
                <Grid>
                  <Border Width="3"
                          CornerRadius="2"
                          Background="{DynamicResource MetricBlueBrush}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Margin="-14,-12,0,-12"/>
                  <Grid RowDefinitions="Auto,*,Auto" Margin="10,0,0,0">
                    <TextBlock Grid.Row="0" Text="LEVEL" Classes="metric-label"/>
                    <TextBlock Grid.Row="1" x:Name="MetricLevel" Classes="metric-value blue" Text="-"
                               VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" x:Name="MetricLevelHint" Classes="metric-subtext" Text=""/>
                  </Grid>
                </Grid>
              </Border>

              <Border Grid.Column="1" Classes="metric-card empty" Margin="8,0,0,0">
                <Grid>
                  <Border Width="3"
                          CornerRadius="2"
                          Background="{DynamicResource MetricGreenBrush}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Margin="-14,-12,0,-12"/>
                  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="10,0,0,0">
                    <TextBlock Grid.Row="0" Text="HP" Classes="metric-label"/>
                    <TextBlock Grid.Row="1" x:Name="MetricHp" Classes="metric-value green" Text="-"
                               VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" x:Name="MetricHpHint" Classes="metric-subtext" Text=""/>
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                      <Border Background="#1634D399" CornerRadius="999" Height="4"/>
                      <Border x:Name="HpBar" Background="{DynamicResource MetricGreenBrush}"
                              CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Border>

              <Border Grid.Column="2" Classes="metric-card empty" Margin="8,0,0,0">
                <Grid>
                  <Border Width="3"
                          CornerRadius="2"
                          Background="{DynamicResource MetricPurpleBrush}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Margin="-14,-12,0,-12"/>
                  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="10,0,0,0">
                    <TextBlock Grid.Row="0" Text="MP" Classes="metric-label"/>
                    <TextBlock Grid.Row="1" x:Name="MetricMp" Classes="metric-value purple" Text="-"
                               VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" x:Name="MetricMpHint" Classes="metric-subtext" Text=""/>
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                      <Border Background="#16A78BFA" CornerRadius="999" Height="4"/>
                      <Border x:Name="MpBar" Background="{DynamicResource MetricPurpleBrush}"
                              CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Border>

              <Border Grid.Column="3" Classes="metric-card empty" Margin="8,0,0,0">
                <Grid>
                  <Border Width="3"
                          CornerRadius="2"
                          Background="{DynamicResource MetricAmberBrush}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Margin="-14,-12,0,-12"/>
                  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="10,0,0,0">
                    <TextBlock Grid.Row="0" Text="EXP" Classes="metric-label"/>
                    <TextBlock Grid.Row="1" x:Name="MetricExp" Classes="metric-value amber" Text="-"
                               VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" x:Name="MetricExpHint" Classes="metric-subtext" Text=""/>
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                      <Border Background="#18F59E0B" CornerRadius="999" Height="4"/>
                      <Border x:Name="ExpBar" Background="{DynamicResource MetricAmberBrush}"
                              CornerRadius="999" Height="4" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Border>
            </Grid>

            <ContentControl Grid.Row="1" x:Name="ContentHost" Padding="12,10,12,12"/>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Panel>
</Window>



