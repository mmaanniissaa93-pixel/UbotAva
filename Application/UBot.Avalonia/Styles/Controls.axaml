п»ї<Styles
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ГўвЂўВђГўвЂўВђ SIDEBAR ITEM ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Button.sidebar-item">
    <Setter Property="Height" Value="34"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.sidebar-item:pointerover">
    <Setter Property="Background" Value="#18AACCEE"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>
  <Style Selector="Button.sidebar-item.active">
    <Setter Property="Background" Value="#2478A0CC"/>
    <Setter Property="BorderBrush" Value="#426688AA"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ SIDEBAR GROUP LABEL ГўвЂўВђГўвЂўВђ -->
  <Style Selector="TextBlock.sidebar-group">
    <Setter Property="FontSize" Value="9.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.8"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="Margin" Value="12,10,12,3"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ TAB BUTTON ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Button.tab-btn">
    <Setter Property="Height" Value="28"/>
    <Setter Property="Padding" Value="14,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.tab-btn:pointerover">
    <Setter Property="Background" Value="#1678A0CC"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>
  <Style Selector="Button.tab-btn.active">
    <Setter Property="Background" Value="#2860A0CC"/>
    <Setter Property="BorderBrush" Value="#4260A0CC"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ LANG BUTTON ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Button.lang-btn">
    <Setter Property="Height" Value="22"/>
    <Setter Property="MinWidth" Value="30"/>
    <Setter Property="Padding" Value="6,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.lang-btn:pointerover">
    <Setter Property="Background" Value="#228FA8CC"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>
  <Style Selector="Button.lang-btn.active">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0" Color="#6022D3A6"/>
          <GradientStop Offset="1" Color="#40F59E0B"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="White"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ STATUS CHIP ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.status-running">
    <Setter Property="Background" Value="#1A34D399"/>
    <Setter Property="BorderBrush" Value="#5034D399"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="26"/>
  </Style>
  <Style Selector="Border.status-stopped">
    <Setter Property="Background" Value="#1AF26C6C"/>
    <Setter Property="BorderBrush" Value="#50F26C6C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="26"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ TOPBAR PILL ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.topbar-pill">
    <Setter Property="Background" Value="#128FA8CC"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="Height" Value="26"/>
  </Style>
  <Style Selector="Border.topbar-pill.waiting">
    <Setter Property="Background" Value="#22F59E0B"/>
    <Setter Property="BorderBrush" Value="#55F59E0B"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ ACTION BUTTONS ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Button.btn">
    <Setter Property="Height" Value="30"/>
    <Setter Property="MinWidth" Value="80"/>
    <Setter Property="Padding" Value="12,0"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Background" Value="{DynamicResource BtnDefaultBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.btn:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
  </Style>
  <Style Selector="Button.btn:disabled">
    <Setter Property="Opacity" Value="0.45"/>
  </Style>
  <Style Selector="Button.btn.start">
    <Setter Property="Background" Value="{DynamicResource BtnStartBrush}"/>
    <Setter Property="BorderBrush" Value="#5534D399"/>
    <Setter Property="Foreground" Value="#042E1E"/>
  </Style>
  <Style Selector="Button.btn.danger">
    <Setter Property="Background" Value="{DynamicResource BtnDangerBrush}"/>
    <Setter Property="BorderBrush" Value="#88F26C6C"/>
    <Setter Property="Foreground" Value="#FFE4E4"/>
  </Style>
  <Style Selector="Button.btn.blue">
    <Setter Property="Background" Value="{DynamicResource BtnBlueBrush}"/>
    <Setter Property="BorderBrush" Value="#555BA3F5"/>
    <Setter Property="Foreground" Value="#E8F4FF"/>
  </Style>
  <Style Selector="Button.btn.ghost">
    <Setter Property="Background" Value="#18F59E0B"/>
    <Setter Property="BorderBrush" Value="#55F59E0B"/>
    <Setter Property="Foreground" Value="#FFD48A"/>
  </Style>
  <Style Selector="Button.btn.icon">
    <Setter Property="MinWidth" Value="30"/>
    <Setter Property="Width" Value="30"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ METRIC CARD ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.metric-card">
    <Setter Property="Background" Value="#CC0D1422"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="16,12"/>
  </Style>
  <Style Selector="TextBlock.metric-label">
    <Setter Property="FontSize" Value="9.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.4"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
  </Style>
  <Style Selector="TextBlock.metric-value">
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>
  <Style Selector="TextBlock.metric-value.green">
    <Setter Property="Foreground" Value="{DynamicResource MetricGreenBrush}"/>
  </Style>
  <Style Selector="TextBlock.metric-value.blue">
    <Setter Property="Foreground" Value="{DynamicResource MetricBlueBrush}"/>
  </Style>
  <Style Selector="TextBlock.metric-value.amber">
    <Setter Property="Foreground" Value="{DynamicResource MetricAmberBrush}"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ LEGACY INPUT ГўвЂўВђГўвЂўВђ -->
  <Style Selector="TextBox.field">
    <Setter Property="Background" Value="#DD0E1826"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="32"/>
  </Style>
  <Style Selector="TextBox.field:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ SECTION PANEL ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="16,14"/>
  </Style>

  <Style Selector="TextBlock.panel-title">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.2"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="TextBlock.hint">
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="Margin" Value="0,4,0,0"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ CHECKBOX ГўвЂўВђГўвЂўВђ -->
  <Style Selector="CheckBox.check">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,2"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ SCROLLBAR ГўвЂўВђГўвЂўВђ -->
  <Style Selector="ScrollBar">
    <Setter Property="Width" Value="6"/>
  </Style>
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#446688AA"/>
    <Setter Property="CornerRadius" Value="999"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ SELECT TRIGGER ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.select-trigger">
    <Setter Property="Height" Value="32"/>
    <Setter Property="MinWidth" Value="110"/>
    <Setter Property="Background" Value="#DD0E1826"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Border.select-trigger:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
  </Style>
  <Style Selector="Border.select-menu">
    <Setter Property="Background" Value="#FC080C14"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="6"/>
  </Style>
  <Style Selector="Border.select-item">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="9,7"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Border.select-item:pointerover">
    <Setter Property="Background" Value="#2878A0CC"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
  </Style>
  <Style Selector="Border.select-item.selected">
    <Setter Property="Background" Value="#1E5BA3F5"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
  </Style>

  <!-- ГўвЂўВђГўвЂўВђ LOG BOARD ГўвЂўВђГўвЂўВђ -->
  <Style Selector="Border.log-board">
    <Setter Property="Background" Value="#0A0B1020"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

</Styles>


