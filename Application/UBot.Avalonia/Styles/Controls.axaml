<Styles
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Border.shell-card">
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="BoxShadow" Value="0 20 44 0 #40000000"/>
  </Style>

  <Style Selector="Button.sidebar-item">
    <Setter Property="Height" Value="36"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button.sidebar-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style Selector="Button.sidebar-item.active">
    <Setter Property="Background" Value="{DynamicResource SidebarItemActiveBgBrush}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Foreground" Value="{DynamicResource SidebarItemActiveFgBrush}"/>
  </Style>

  <Style Selector="Button.sidebar-item.active /template/ ContentPresenter">
    <Setter Property="Foreground" Value="{DynamicResource SidebarItemActiveFgBrush}"/>
  </Style>

  <!-- Active nav icon turns accent blue -->
  <Style Selector="Button.sidebar-item.active Path">
    <Setter Property="Stroke" Value="{DynamicResource SidebarItemActiveFgBrush}"/>
  </Style>

  <Style Selector="TextBlock.sidebar-group">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.6"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="Margin" Value="12,12,12,4"/>
  </Style>

  <Style Selector="TextBlock.sidebar-group-label">
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="LetterSpacing" Value="0.1"/>
    <Setter Property="Opacity" Value="0.8"/>
  </Style>

  <Style Selector="Button.tab-btn">
    <Setter Property="Height" Value="28"/>
    <Setter Property="Padding" Value="16,0"/>
    <Setter Property="Background" Value="{DynamicResource TabBtnBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource TabBtnBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="14"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Button.tab-btn:pointerover">
    <Setter Property="Background" Value="{DynamicResource TabBtnHoverBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource TabBtnHoverBorderBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style Selector="Button.tab-btn.active">
    <Setter Property="Background" Value="{DynamicResource TabBtnActiveBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <!-- Toggle-style language/theme switch -->
  <Style Selector="Button.lang-btn">
    <Setter Property="Height" Value="24"/>
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Opacity" Value="0.7"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Button.lang-btn:pointerover">
    <Setter Property="Background" Value="{DynamicResource LangBtnHoverBgBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Opacity" Value="1"/>
  </Style>

  <Style Selector="Button.lang-btn.active">
    <Setter Property="Background" Value="{DynamicResource LangBtnActiveBgBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Opacity" Value="1"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>

  <!-- ═══ Status badge variants ═══ -->
  <Style Selector="Border.status-chip">
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
  </Style>

  <Style Selector="Border.status-running">
    <Setter Property="Background" Value="{DynamicResource StatusRunningBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusRunningBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
  </Style>

  <Style Selector="Border.status-stopped">
    <Setter Property="Background" Value="{DynamicResource StatusStoppedBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusStoppedBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
  </Style>

  <Style Selector="Border.status-waiting">
    <Setter Property="Background" Value="{DynamicResource StatusWaitingBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusWaitingBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
  </Style>

  <Style Selector="Border.status-connected">
    <Setter Property="Background" Value="{DynamicResource StatusConnectedBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusConnectedBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
  </Style>

  <Style Selector="Border.topbar-pill">
    <Setter Property="Background" Value="{DynamicResource TopbarPillBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="Height" Value="26"/>
  </Style>

  <Style Selector="Border.topbar-pill.waiting">
    <Setter Property="Background" Value="{DynamicResource StatusWaitingBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusWaitingBorderBrush}"/>
  </Style>

  <Style Selector="Button.btn">
    <Setter Property="Height" Value="30"/>
    <Setter Property="MinWidth" Value="86"/>
    <Setter Property="Padding" Value="12,0"/>
    <Setter Property="CornerRadius" Value="9"/>
    <Setter Property="Background" Value="{DynamicResource BtnDefaultBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="RenderTransform" Value="translate(0px,0px)"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.14"/>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14"/>
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Button.btn:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
    <Setter Property="RenderTransform" Value="translate(0px,-1px)"/>
  </Style>

  <Style Selector="Button.btn:disabled">
    <Setter Property="Opacity" Value="0.45"/>
  </Style>

  <!-- Primary action: the single powerful Start/Stop toggle -->
  <Style Selector="Button.btn.primary">
    <Setter Property="Height" Value="34"/>
    <Setter Property="MinWidth" Value="120"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="CornerRadius" Value="10"/>
  </Style>

  <Style Selector="Button.btn.primary.go">
    <Setter Property="Background" Value="{DynamicResource BtnStartBrush}"/>
    <Setter Property="BorderBrush" Value="#6634D399"/>
    <Setter Property="Foreground" Value="#F0FFFFFF"/>
  </Style>

  <Style Selector="Button.btn.primary.go:pointerover">
    <Setter Property="BorderBrush" Value="#9934D399"/>
  </Style>

  <Style Selector="Button.btn.primary.halt">
    <Setter Property="Background" Value="{DynamicResource BtnDangerBrush}"/>
    <Setter Property="BorderBrush" Value="#88F26C6C"/>
    <Setter Property="Foreground" Value="#FFE4E4"/>
  </Style>

  <Style Selector="Button.btn.primary.halt:pointerover">
    <Setter Property="BorderBrush" Value="#CCF26C6C"/>
  </Style>

  <!-- Secondary actions: demoted buttons -->
  <Style Selector="Button.btn.secondary">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Background" Value="{DynamicResource SecondaryBtnBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="Button.btn.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource SecondaryBtnHoverBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style Selector="Button.btn.ghost-outline">
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="0"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{DynamicResource GhostBtnBorderBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource GhostBtnFgBrush}"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="Button.btn.ghost-outline:pointerover">
    <Setter Property="Background" Value="{DynamicResource GhostBtnHoverBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource GhostBtnHoverBorderBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource GhostBtnHoverFgBrush}"/>
  </Style>

  <Style Selector="Button.btn.ghost-outline Path">
    <Setter Property="Stroke" Value="{DynamicResource GhostBtnFgBrush}"/>
  </Style>

  <Style Selector="Button.btn.start">
    <Setter Property="Background" Value="{DynamicResource BtnStartBrush}"/>
    <Setter Property="BorderBrush" Value="#5534D399"/>
    <Setter Property="Foreground" Value="#042E1E"/>
  </Style>

  <Style Selector="Button.btn.danger">
    <Setter Property="Background" Value="{DynamicResource BtnDangerBrush}"/>
    <Setter Property="BorderBrush" Value="#88F26C6C"/>
    <Setter Property="Foreground" Value="#FFE4E4"/>
  </Style>

  <Style Selector="Button.btn.blue">
    <Setter Property="Background" Value="{DynamicResource BtnBlueBrush}"/>
    <Setter Property="BorderBrush" Value="#5A6CA9F2"/>
    <Setter Property="Foreground" Value="#E8F4FF"/>
  </Style>

  <Style Selector="Button.btn.ghost">
    <Setter Property="Background" Value="#1BF59E0B"/>
    <Setter Property="BorderBrush" Value="#58F59E0B"/>
    <Setter Property="Foreground" Value="#FFD48A"/>
  </Style>

  <Style Selector="Button.btn.icon">
    <Setter Property="MinWidth" Value="30"/>
    <Setter Property="Width" Value="30"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <Style Selector="Border.metric-card">
    <Setter Property="Background" Value="{DynamicResource MetricCardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="14,12"/>
    <Setter Property="Height" Value="100"/>
    <Setter Property="BoxShadow" Value="0 10 22 0 #2A000000"/>
  </Style>


  <Style Selector="TextBlock.metric-label">
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.2"/>
    <Setter Property="Foreground" Value="{DynamicResource MetricLabelBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-value">
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-value.green">
    <Setter Property="Foreground" Value="{DynamicResource MetricValueGreenBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-value.blue">
    <Setter Property="Foreground" Value="{DynamicResource MetricValueBlueBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-value.amber">
    <Setter Property="Foreground" Value="{DynamicResource MetricValueAmberBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-value.purple">
    <Setter Property="Foreground" Value="{DynamicResource MetricValuePurpleBrush}"/>
  </Style>

  <Style Selector="TextBlock.metric-subtext">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource MetricSubtextBrush}"/>
  </Style>

  <Style Selector="TextBox.field">
    <Setter Property="Background" Value="{DynamicResource FieldBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="9"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Height" Value="32"/>
  </Style>

  <Style Selector="TextBox.field.number">
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="Width" Value="72"/>
  </Style>

  <Style Selector="TextBox.field:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Background" Value="{DynamicResource FieldBgFocusBrush}"/>
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="16,14"/>
  </Style>

  <Style Selector="Border.section-card">
    <Setter Property="Background" Value="{DynamicResource CardSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="ClipToBounds" Value="True"/>
    <Setter Property="BoxShadow" Value="0 12 24 0 #25000000"/>
  </Style>


  <Style Selector="Border.metric-card.empty TextBlock.metric-label">
    <Setter Property="Opacity" Value="0.95"/>
  </Style>
  <Style Selector="Border.metric-card.empty TextBlock.metric-value">
    <Setter Property="Opacity" Value="0.9"/>
  </Style>
  <Style Selector="Border.metric-card.empty TextBlock.metric-subtext">
    <Setter Property="Foreground" Value="{DynamicResource MetricSubtextBrush}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="Border.section-header">
    <Setter Property="Background" Value="{DynamicResource SectionHeaderBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource SectionHeaderBorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="11,9"/>
  </Style>

  <Style Selector="TextBlock.section-header-text">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="0.25"/>
    <Setter Property="Foreground" Value="{DynamicResource SectionHeaderTextBrush}"/>
  </Style>

  <Style Selector="Border.section-pill">
    <Setter Property="Background" Value="{DynamicResource TopbarPillBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="10,2"/>
    <Setter Property="Height" Value="22"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="TextBlock.section-pill-text">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="LetterSpacing" Value="0.8"/>
    <Setter Property="Foreground" Value="{DynamicResource GroupCaptionBrush}"/>
  </Style>

  <Style Selector="Border.section-separator">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource SectionSeparatorBrush}"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="Margin" Value="0,8"/>
  </Style>

  <Style Selector="TextBlock.panel-title">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="LetterSpacing" Value="1.2"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="TextBlock.group-caption">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource GroupCaptionBrush}"/>
    <Setter Property="LetterSpacing" Value="0.25"/>
    <Setter Property="Margin" Value="0,0,0,4"/>
  </Style>

  <Style Selector="TextBlock.hint">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="FontStyle" Value="Italic"/>
    <Setter Property="LineHeight" Value="17"/>
    <Setter Property="Opacity" Value="0.92"/>
  </Style>

  <Style Selector="TextBlock.sidebar-group">
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
    <Setter Property="LetterSpacing" Value="0.1"/>
    <Setter Property="Margin" Value="12,14,12,6"/>
    <Setter Property="Opacity" Value="0.8"/>
  </Style>

  <Style Selector="CheckBox.check">
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,3"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="ScrollBar">
    <Setter Property="Width" Value="6"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#446688AA"/>
    <Setter Property="CornerRadius" Value="999"/>
  </Style>

  <Style Selector="Border.select-trigger">
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="MinWidth" Value="110"/>
    <Setter Property="Background" Value="{DynamicResource FieldBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="9"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Border.select-trigger:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
  </Style>

  <Style Selector="Border.select-trigger:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Background" Value="{DynamicResource FieldBgFocusBrush}"/>
  </Style>

  <Style Selector="Border.select-menu">
    <Setter Property="Background" Value="{DynamicResource SelectMenuBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="6"/>
  </Style>

  <Style Selector="Border.select-item">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="9,7"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Border.select-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource SelectItemHoverBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
  </Style>

  <Style Selector="Border.select-item.selected">
    <Setter Property="Background" Value="{DynamicResource SelectItemSelectedBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
  </Style>

<Style Selector="Border.log-board">
    <Setter Property="Background" Value="{DynamicResource LogBoardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="Button.window-btn">
    <Setter Property="Width" Value="30"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Button.window-btn:pointerover">
    <Setter Property="Background" Value="{DynamicResource WindowButtonHoverBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}"/>
  </Style>

  <Style Selector="Button.window-btn.close:pointerover">
    <Setter Property="Background" Value="{DynamicResource WindowButtonCloseHoverBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource WindowButtonCloseHoverBrush}"/>
  </Style>

  <Style Selector="Button.window-btn.close:pointerover Path">
    <Setter Property="Stroke" Value="White"/>
  </Style>

</Styles>
