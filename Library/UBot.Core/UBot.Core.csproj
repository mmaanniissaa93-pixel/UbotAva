<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>disable</ImplicitUsings>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <Description>Acts as UBot Library- includes all neccessary logic that the bot and 3rd party applications require.</Description>
    <Copyright>Copyright ©  2018 - 2026, UBot Team</Copyright>
    <PackageProjectUrl>https://github.com/mmaanniissaa93-pixel/ubot</PackageProjectUrl>
    <PackageReadmeFile></PackageReadmeFile>
    <RepositoryUrl>https://github.com/mmaanniissaa93-pixel/ubot</RepositoryUrl>
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\UBot.Core.Abstractions\UBot.Core.Abstractions.csproj" />
    <ProjectReference Include="..\UBot.Core.Network\UBot.Core.Network.csproj" />
    <ProjectReference Include="..\UBot.FileSystem\UBot.FileSystem.csproj" />
    <ProjectReference Include="..\UBot.GameData\UBot.GameData.csproj" />
    <ProjectReference Include="..\UBot.NavMeshApi\UBot.NavMeshApi.csproj" />
  </ItemGroup>

</Project>
