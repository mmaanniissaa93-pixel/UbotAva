<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <PlatformTarget>x86</PlatformTarget>
    <Description>Composition root for UBot runtime dependency injection.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\UBot.Core\UBot.Core.csproj" />
    <ProjectReference Include="..\UBot.Core.Abstractions\UBot.Core.Abstractions.csproj" />
    <ProjectReference Include="..\UBot.Core.Services\UBot.Core.Services.csproj" />
    <ProjectReference Include="..\UBot.Protocol\UBot.Protocol.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
  </ItemGroup>
</Project>
